# Pins and identity vars for the ToolHive demo sandbox.
#
# Sourced by bootstrap.sh and cleanup.sh. Renovate scans the chart/image
# pins in this file in place (see customManagers in renovate.json).

# Cluster identity. CLUSTER_NAME must match metadata.name in kind-config.yaml
CLUSTER_NAME="toolhive-demo-sandbox"
KUBECONFIG_FILE="kubeconfig-toolhive-demo.yaml"

# Namespace where the ToolHive operator and all MCP resources live
RELEASE_NAMESPACE="toolhive-system"

# MCPRegistry resource name (used by demo-manifests/registry-server-mcpregistry.yaml)
REGISTRY_RESOURCE_NAME="toolhive-registry"

# Keycloak realm name (also baked into infra/keycloak.yaml's realm import)
KC_REALM="toolhive-demo"

# Shared infra pins
GATEWAY_API_VERSION="v1.5.0" # renovate: datasource=github-releases depName:kubernetes-sigs/gateway-api
TRAEFIK_CHART_VERSION="40.3.0" # renovate: datasource=helm depName=traefik registryUrl=https://traefik.github.io/charts
CERT_MANAGER_CHART_VERSION="v1.20.2" # renovate: datasource=docker depName=quay.io/jetstack/charts/cert-manager versioning=semver
OPENTELEMETRY_OPERATOR_VERSION="v0.153.0" # renovate: datasource=github-releases depName=open-telemetry/opentelemetry-operator
LOKI_CHART_VERSION="17.4.1" # renovate: datasource=helm depName=loki registryUrl=https://grafana-community.github.io/helm-charts
FLUENT_BIT_CHART_VERSION="0.57.7" # renovate: datasource=helm depName=fluent-bit registryUrl=https://fluent.github.io/helm-charts
PROMETHEUS_CHART_VERSION="29.12.0" # renovate: datasource=helm depName=prometheus registryUrl=https://prometheus-community.github.io/helm-charts
GRAFANA_CHART_VERSION="12.4.5" # renovate: datasource=helm depName=grafana registryUrl=https://grafana-community.github.io/helm-charts
CLOUDNATIVE_PG_CHART_VERSION="0.28.3" # renovate: datasource=helm depName=cloudnative-pg registryUrl=https://cloudnative-pg.github.io/charts
KEYCLOAK_VERSION="26.6.3" # renovate: datasource=docker depName=quay.io/keycloak/keycloak versioning=semver

# ToolHive platform pins
TOOLHIVE_OPERATOR_CRDS_CHART_VERSION="0.29.3" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive/toolhive-operator-crds
TOOLHIVE_OPERATOR_CHART_VERSION="0.29.3" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive/toolhive-operator
REGISTRY_SERVER_VERSION="v1.4.6" # renovate: datasource=docker depName=ghcr.io/stacklok/thv-registry-api
CLOUD_UI_CHART_VERSION="0.6.1" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive-cloud-ui/toolhive-cloud-ui
