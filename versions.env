# Pins and identity vars for the ToolHive demo sandbox.
#
# Sourced by bootstrap.sh and cleanup.sh. Renovate scans the chart/image
# pins in this file in place (see customManagers in renovate.json).

# Cluster identity. CLUSTER_NAME must match metadata.name in kind-config.yaml
CLUSTER_NAME="toolhive-demo-sandbox"
KUBECONFIG_FILE="kubeconfig-toolhive-demo.yaml"

# Namespace where the ToolHive operator and all MCP resources live
RELEASE_NAMESPACE="toolhive-system"

# Keycloak realm name (also baked into infra/keycloak.yaml's realm import)
KC_REALM="toolhive-demo"

# Shared infra pins
GATEWAY_API_VERSION="v1.5.0" # renovate: datasource=github-releases depName:kubernetes-sigs/gateway-api
TRAEFIK_CHART_VERSION="41.0.2" # renovate: datasource=helm depName=traefik registryUrl=https://traefik.github.io/charts
CERT_MANAGER_CHART_VERSION="v1.21.0" # renovate: datasource=docker depName=quay.io/jetstack/charts/cert-manager versioning=semver
OPENTELEMETRY_OPERATOR_VERSION="v0.156.0" # renovate: datasource=github-releases depName=open-telemetry/opentelemetry-operator
LOKI_CHART_VERSION="18.5.0" # renovate: datasource=helm depName=loki registryUrl=https://grafana-community.github.io/helm-charts
FLUENT_BIT_CHART_VERSION="0.57.9" # renovate: datasource=helm depName=fluent-bit registryUrl=https://fluent.github.io/helm-charts
PROMETHEUS_CHART_VERSION="29.17.0" # renovate: datasource=helm depName=prometheus registryUrl=https://prometheus-community.github.io/helm-charts
GRAFANA_CHART_VERSION="12.7.2" # renovate: datasource=helm depName=grafana registryUrl=https://grafana-community.github.io/helm-charts
CLOUDNATIVE_PG_CHART_VERSION="0.29.0" # renovate: datasource=helm depName=cloudnative-pg registryUrl=https://cloudnative-pg.github.io/charts
KEYCLOAK_VERSION="26.7.0" # renovate: datasource=docker depName=quay.io/keycloak/keycloak versioning=semver

# ToolHive platform pins
TOOLHIVE_OPERATOR_CRDS_CHART_VERSION="0.40.0" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive/toolhive-operator-crds
TOOLHIVE_OPERATOR_CHART_VERSION="0.40.0" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive/toolhive-operator
REGISTRY_SERVER_CHART_VERSION="1.5.0" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive-registry-server
CLOUD_UI_CHART_VERSION="0.6.2" # renovate: datasource=docker depName=ghcr.io/stacklok/toolhive-cloud-ui/toolhive-cloud-ui
