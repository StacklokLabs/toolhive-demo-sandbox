# ─── Ingress hostnames ────────────────────────────────────────────────
# Traefik ingress hostnames for each service. These must resolve to your
# cluster's Traefik external IP.
#
# When running locally (e.g. Kind + cloud-provider-kind), bootstrap.sh
# auto-generates hostnames using traefik.me (e.g. mcp-172-18-0-2.traefik.me)
# which resolve to the Traefik IP without manual DNS setup.
#
# For custom hostnames, add entries to /etc/hosts pointing to the Traefik IP:
#
#   # Get the Traefik external IP:
#   #   kubectl get gateway traefik-gateway -n traefik -o jsonpath='{.status.addresses[0].value}'
#
#   <TRAEFIK_IP>  mcp.demo.example.com
#   <TRAEFIK_IP>  ui.demo.example.com
#   <TRAEFIK_IP>  auth.demo.example.com
#   <TRAEFIK_IP>  registry.demo.example.com
#   <TRAEFIK_IP>  aws-mcp.demo.example.com

# Hostname for MCP server endpoints (vmcp-demo, mkp, etc.)
MCP_HOSTNAME=mcp.demo.example.com

# Hostname for the Cloud UI frontend
UI_HOSTNAME=ui.demo.example.com

# Hostname for the OIDC mock provider (used by Cloud UI)
AUTH_HOSTNAME=auth.demo.example.com

# Hostname for the ToolHive registry server
REGISTRY_HOSTNAME=registry.demo.example.com

# Hostname for the AWS MCP Remote Proxy
AWS_MCP_HOSTNAME=aws-mcp.demo.example.com

# ─── Cloud UI ─────────────────────────────────────────────────────────

# Cloud UI container image tag
CLOUD_UI_VERSION=latest

# ─── Okta (for AWS STS demo) ─────────────────────────────────────────
# See demo-manifests/mcpremoteproxy-aws-mcp.yaml for full Okta setup instructions.

# Okta org domain (e.g. dev-12345.okta.com)
OKTA_DOMAIN=dev-12345.okta.com

# Client ID from the Okta OIDC Web Application
OKTA_CLIENT_ID=

# Client secret from the Okta OIDC Web Application
OKTA_CLIENT_SECRET=

# ─── AWS (for AWS STS demo) ──────────────────────────────────────────
# See demo-manifests/mcpremoteproxy-aws-mcp.yaml for full AWS IAM setup instructions.

# 12-digit AWS account ID
AWS_ACCOUNT_ID=123456789012

# AWS region for the STS endpoint and MCP server
AWS_REGION=us-east-1
