# Okta org domain (e.g. dev-12345.okta.com)
OKTA_DOMAIN=

# Client ID from the Okta OIDC Web Application
OKTA_CLIENT_ID=

# Client secret from the Okta OIDC Web Application
OKTA_CLIENT_SECRET=

# 12-digit AWS account ID
AWS_ACCOUNT_ID=

# AWS region for the STS endpoint and MCP server
AWS_REGION=us-east-1
