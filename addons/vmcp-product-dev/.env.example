# Entra ID authorization server issuer URL
ENTRA_ISSUER_URL=https://login.microsoftonline.com/<TENANT-ID>/v2.0

# Entra ID application client credentials (see the README for the app
# registration setup).
VMCP_ENTRA_CLIENT_ID=replace-me
VMCP_ENTRA_CLIENT_SECRET=replace-me

# Public hostname served by the Cloudflare tunnel (no scheme, no trailing slash).
# Must match the Entra ID app's redirect URI host and the authorization server's audience.
VMCP_PRODUCT_CLOUDFLARED_DOMAIN=<subdomain>.stacklok-demo.com

# Token for the Cloudflare tunnel that fronts this vMCP.
VMCP_PRODUCT_CLOUDFLARED_TUNNEL_TOKEN=replace-me

# No GitLab credentials needed: the embedded auth server registers its OAuth
# client against gitlab.com at runtime via Dynamic Client Registration.
