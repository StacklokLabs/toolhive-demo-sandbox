# Okta authorization server issuer URL (includes /oauth2/<auth-server-id>)
OKTA_ISSUER_URL=https://integrator-XXXXXXX.okta.com/oauth2/ausXXXXXXXX

# Okta application client credentials
VMCP_OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXXXXX
VMCP_OKTA_CLIENT_SECRET=replace-me

# Public hostname served by the Cloudflare tunnel (no scheme, no trailing slash).
# Must match the Okta app's redirect URI host and the authorization server's audience.
VMCP_OKTA_CLOUDFLARED_DOMAIN=<subdomain>.stacklok-demo.com

# Token for the Cloudflare tunnel that fronts this vMCP.
VMCP_OKTA_CLOUDFLARED_TUNNEL_TOKEN=replace-me
