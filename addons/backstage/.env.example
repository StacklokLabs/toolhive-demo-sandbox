# Backstage addon configuration
# Copy to .env and fill in values

# (Optional) GitHub token for GitHub integrations in Backstage
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# (Optional) Override the Backstage container image
# BACKSTAGE_IMAGE=backstage-toolhive-demo:latest

# (Optional) Override the in-cluster registry API URL.
# deploy.sh discovers this automatically via app.kubernetes.io/component=registry-api.
# REGISTRY_SVC_URL=http://registry-api.stacklok-system.svc.cluster.local:8080
